# ───────────────────────────── Hive API ─────────────────────────────
NODE_ENV=development
PORT=4000
# Public base URL of this API (used for webhooks & payment redirects).
# Locally, set this to your tunnel URL, e.g. https://abc123.ngrok-free.app
PUBLIC_BASE_URL=http://localhost:4000

# ───────────────────────────── Database ─────────────────────────────
# Easiest zero-setup option: a free Neon (neon.tech) or Supabase Postgres.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/hive?sslmode=require

# ───────────────────────────── AI (Groq) ────────────────────────────
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=
# Text + tool-calling model. openai/gpt-oss-20b = reliable tool-calling + headroom.
# (llama-3.1-8b-instant is faster/cheaper but unreliable with many tools;
#  llama-3.3-70b-versatile is highest quality but only ~100k tokens/day on free tier.)
GROQ_MODEL=openai/gpt-oss-20b
# Vision model used when a product image is sent (image -> listing).
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ──────────────────────────── WhatsApp ──────────────────────────────
# Which provider to use: "twilio" (fast, sandbox in minutes) or "meta".
WHATSAPP_PROVIDER=twilio

# --- Twilio WhatsApp (https://console.twilio.com) ---
# Twilio Sandbox: Messaging > Try it out > Send a WhatsApp message.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# The Twilio WhatsApp sender (sandbox default shown). Format: whatsapp:+E164
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Set true in production to verify inbound X-Twilio-Signature.
TWILIO_VALIDATE_SIGNATURE=false

# --- Meta WhatsApp Cloud API (only if WHATSAPP_PROVIDER=meta) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# Any random string; must match what you enter in the Meta webhook config.
WHATSAPP_VERIFY_TOKEN=hive-verify-token
WHATSAPP_API_VERSION=v21.0

# ───────────────────────────── Nomba ────────────────────────────────
# From Nomba dashboard. https://www.nomba.com
# Sandbox = test payments (no real money). Use https://api.nomba.com to go live.
NOMBA_BASE_URL=https://sandbox.nomba.com
NOMBA_CLIENT_ID=
NOMBA_PRIVATE_KEY=
# Parent (main) account ID — sent in the accountId header.
NOMBA_ACCOUNT_ID=
# Sub-account ID — calls are scoped/settled here.
NOMBA_SUB_ACCOUNT_ID=
# Used to verify incoming Nomba webhook signatures.
NOMBA_WEBHOOK_SECRET=

# ─────────────────────────── Cloudinary (optional) ──────────────────
CLOUDINARY_URL=
