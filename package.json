{
  "name": "hive",
  "version": "0.1.0",
  "private": true,
  "description": "Hive — the first AI employee for African SMEs. Runs a merchant's business through WhatsApp, powered by Nomba.",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "pnpm --filter @hive/api dev",
    "dev:web": "pnpm --filter @hive/web dev",
    "dev:all": "pnpm --parallel --filter @hive/api --filter @hive/web dev",
    "build": "pnpm -r build",
    "db:push": "pnpm --filter @hive/api db:push",
    "db:studio": "pnpm --filter @hive/api db:studio",
    "db:seed": "pnpm --filter @hive/api db:seed"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "puppeteer-core": "^25.2.1"
  }
}
